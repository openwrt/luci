{
	"luci-proto-openvpn": {
		"description": "Grant access to LuCI openvpn procedures",
		"read": {
			"file": {
				"/bin/mkdir -p /etc/openvpn/*": [ "exec" ],
				"/etc/openvpn/*": [ "read" ]
			},
			"ubus": {
				"luci.openvpn": [
					"*"
				]
			},
			"uci": [ "network" ]
		},
		"write": {
			"file": {
				"/etc/openvpn/*": [ "write", "remove" ]
			},
			"ubus": {
				"luci.openvpn": [
					"*"
				]
			},
			"uci": [ "network" ]
		}
	}
}
