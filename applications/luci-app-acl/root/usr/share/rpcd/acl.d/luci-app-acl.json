{
	"luci-app-acl": {
		"description": "Grant access to ACL configuration",
		"read": {
			"cgi-io": [ "list", "read" ],
			"file": {
				"/etc/passwd": [ "read" ],
				"/usr/sbin/uhttpd": [ "list" ],
				"/usr/sbin/uhttpd -m *": [ "exec" ],
				"/usr/libexec/check_policy": [ "exec" ],
				"/usr/share/rpcd/acl.d": [ "list" ],
				"/usr/share/rpcd/acl.d/*.json": [ "read" ]
			},
			"uci": [ "rpcd", "luci_plugins" ]
		},
		"write": {
			"uci": [ "rpcd" ],
			"ubus": {
				"luci": [ "setPassword" ]
			}
		}
	}
}
