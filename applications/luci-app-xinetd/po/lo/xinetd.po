#: applications/luci-app-xinetd/htdocs/luci-static/resources/view/xinetd/xinetd.js:105
msgid "UNLISTED"
msgstr "ບໍ່ໄດ້ຢູ່ໃນລາຍຊື່ (UNLISTED)"

