#: applications/luci-app-usteer/htdocs/luci-static/resources/view/usteer/usteer.js:538
msgid "Local sta update"
msgstr "ອັບເດດສະຖານີທ້ອງຖິ່ນ"

#: applications/luci-app-usteer/htdocs/luci-static/resources/view/usteer/usteer.js:538
